generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// --------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------

enum TripStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TripVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum LocationCategory {
  CITY
  VILLAGE
  NATURE
  MONASTERY
  BEACH
  CAMPSITE
  PARKING
  ATTRACTION
  ACTIVITY
  OTHER
}

enum MediaType {
  PHOTO
  VIDEO
}

enum NoteType {
  QUICK
  DICTATION
  REPORT
}

enum RouteImportSource {
  GPX
  KML
  GOOGLE_TIMELINE
  MANUAL
}

enum PoiSuggestionStatus {
  SUGGESTED
  ACCEPTED
  REJECTED
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

// --------------------------------------------------------------------
// Models
// --------------------------------------------------------------------

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  displayName   String   @map("display_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  trips Trip[]

  @@map("user")
}

model Trip {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  title         String
  description   String?
  startDate     DateTime?      @map("start_date")
  endDate       DateTime?      @map("end_date")
  status        TripStatus     @default(PLANNING)
  visibility    TripVisibility @default(PRIVATE)
  coverImageId  String?        @unique @map("cover_image_id") @db.Uuid
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverImage      Media?            @relation("TripCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)
  tripDays        TripDay[]
  locations       Location[]
  media           Media[]           @relation("TripMedia")
  notes           Note[]
  routeImports    RouteImport[]
  poiSuggestions  PoiSuggestion[]
  publications    Publication[]

  @@index([userId])
  @@index([status])
  @@map("trip")
}

model TripDay {
  id              String   @id @default(uuid()) @db.Uuid
  tripId          String   @map("trip_id") @db.Uuid
  date            DateTime
  dayNumber       Int      @map("day_number")
  title           String?
  startLocation   String?  @map("start_location")
  endLocation     String?  @map("end_location")
  distanceKm      Decimal? @map("distance_km") @db.Decimal(10, 2)
  drivingMinutes  Int?     @map("driving_minutes")
  dailyNote       String?  @map("daily_note")
  sortOrder       Int      @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  trip            Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  locations       Location[]
  media           Media[]
  notes           Note[]
  poiSuggestions  PoiSuggestion[]

  @@unique([tripId, date])
  @@index([tripId])
  @@map("trip_day")
}

model Location {
  id            String           @id @default(uuid()) @db.Uuid
  tripId        String           @map("trip_id") @db.Uuid
  tripDayId     String?          @map("trip_day_id") @db.Uuid
  name          String
  category      LocationCategory
  latitude      Float
  longitude     Float
  arrivalAt     DateTime?        @map("arrival_at")
  departureAt   DateTime?        @map("departure_at")
  rating        Int?
  description   String?
  isHighlight   Boolean          @default(false) @map("is_highlight")
  sortOrder     Int              @map("sort_order")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripDay   TripDay?  @relation(fields: [tripDayId], references: [id], onDelete: SetNull)
  media     Media[]
  notes     Note[]

  @@index([tripId])
  @@index([tripDayId])
  @@map("location")
}

model Media {
  id              String    @id @default(uuid()) @db.Uuid
  tripId          String    @map("trip_id") @db.Uuid
  tripDayId       String?   @map("trip_day_id") @db.Uuid
  locationId      String?   @map("location_id") @db.Uuid
  type            MediaType
  originalPath    String    @map("original_path")
  thumbnailSm     String?   @map("thumbnail_sm")
  thumbnailMd     String?   @map("thumbnail_md")
  thumbnailLg     String?   @map("thumbnail_lg")
  caption         String?
  takenAt         DateTime? @map("taken_at")
  latitude        Float?
  longitude       Float?
  exifData        Json?     @map("exif_data")
  fileHash        String?   @map("file_hash")
  fileSizeBytes   BigInt?   @map("file_size_bytes")
  width           Int?
  height          Int?
  isHighlight     Boolean   @default(false) @map("is_highlight")
  isCover         Boolean   @default(false) @map("is_cover")
  assigned        Boolean   @default(false)
  sortOrder       Int       @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  trip          Trip      @relation("TripMedia", fields: [tripId], references: [id], onDelete: Cascade)
  tripDay       TripDay?  @relation(fields: [tripDayId], references: [id], onDelete: SetNull)
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  coverForTrip  Trip?     @relation("TripCoverImage")

  @@index([tripId])
  @@index([tripDayId])
  @@index([locationId])
  @@index([fileHash])
  @@map("media")
}

model Note {
  id            String   @id @default(uuid()) @db.Uuid
  tripId        String   @map("trip_id") @db.Uuid
  tripDayId     String?  @map("trip_day_id") @db.Uuid
  locationId    String?  @map("location_id") @db.Uuid
  type          NoteType
  content       String
  isHighlight   Boolean  @default(false) @map("is_highlight")
  sortOrder     Int      @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripDay   TripDay?  @relation(fields: [tripDayId], references: [id], onDelete: SetNull)
  location  Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([tripDayId])
  @@index([locationId])
  @@map("note")
}

model RouteImport {
  id              String            @id @default(uuid()) @db.Uuid
  tripId          String            @map("trip_id") @db.Uuid
  source          RouteImportSource
  filePath        String?           @map("file_path")
  distanceKm      Decimal?          @map("distance_km") @db.Decimal(10, 2)
  recordedFrom    DateTime?         @map("recorded_from")
  recordedUntil   DateTime?         @map("recorded_until")
  createdAt       DateTime          @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("route_import")
}

model PoiSuggestion {
  id                   String              @id @default(uuid()) @db.Uuid
  tripId               String              @map("trip_id") @db.Uuid
  tripDayId            String?             @map("trip_day_id") @db.Uuid
  name                 String
  category             String
  latitude             Float
  longitude            Float
  description          String?
  source               String
  status               PoiSuggestionStatus @default(SUGGESTED)
  distanceFromRouteKm  Decimal?            @map("distance_from_route_km") @db.Decimal(10, 2)
  createdAt            DateTime            @default(now()) @map("created_at")

  trip    Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripDay TripDay? @relation(fields: [tripDayId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([tripDayId])
  @@map("poi_suggestion")
}

model Publication {
  id            String            @id @default(uuid()) @db.Uuid
  tripId        String            @map("trip_id") @db.Uuid
  shareToken    String            @unique @map("share_token")
  title         String
  status        PublicationStatus @default(DRAFT)
  passwordHash  String?           @map("password_hash")
  publishedAt   DateTime?         @map("published_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("publication")
}
